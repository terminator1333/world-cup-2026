# Copy this file to `secrets.toml` and fill in your real values.
# On Streamlit Community Cloud, paste the same contents into
# App → Settings → Secrets (do NOT commit the real secrets.toml).

# --- Supabase (from your project's API settings) ---
SUPABASE_URL = "https://YOUR-PROJECT.supabase.co"
SUPABASE_KEY = "YOUR-SERVICE-ROLE-OR-ANON-KEY"

# --- App control ---
ADMIN_PIN = "change-me"          # gate for the Admin results page
LOCK_DATETIME = "2026-06-11T11:00:00"  # full-tournament picks lock at first kickoff (local naive ISO)
# Knockout Pool (the separate Round-of-32 game) locks at the first knockout kickoff.
# ISO 8601; a bare time is treated as UTC. Default = 2026-06-28 19:00 UTC.
KO_LOCK_DATETIME = "2026-06-28T19:00:00+00:00"

# --- Optional: nicer city photos ---
# Leave unset and the app uses free Creative-Commons photos (Openverse).
# For higher-quality city skylines, get a free key at unsplash.com/developers.
# UNSPLASH_ACCESS_KEY = "your-unsplash-access-key"
